# Terraform local files
.terraform/
.terraform.lock.hcl

# Terraform state files - never commit these
*.tfstate
*.tfstate.*
terraform.tfstate
terraform.tfstate.backup

# Terraform crash logs
crash.log
crash.*.log

# Terraform variable files that may contain secrets
*.tfvars
*.tfvars.json

# Terraform override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform plan files
*.tfplan
*.plan
plan.out

# Checkov reports
reports/
checkov-results.json
checkov-report.json
*.sarif

# Local environment files
.env
.env.*
!.env.example

# macOS files
.DS_Store

# VS Code
.vscode/

# IntelliJ / JetBrains
.idea/

# Python cache, if using Python scripts
__pycache__/
*.pyc
.venv/
venv/

# Logs
*.log